# ========================================
# Resend (メール通知) — 必須
# ========================================
# 発行: https://resend.com/api-keys
RESEND_API_KEY=

# 送信元アドレス。
#   - 独自ドメイン未検証時はこの値を推奨: "Simple Records <onboarding@resend.dev>"
#     ※ただしドメイン検証前はResendアカウント所有者のメールアドレス宛にしか送れない
#   - 独自ドメイン検証後は "Simple Records <noreply@yourdomain.com>" 等に差し替え
MAIL_FROM="Simple Records <onboarding@resend.dev>"

# 通知先（応募を受け取るアドレス）
MAIL_TO=simple.records.2022@gmail.com

# ========================================
# Google Sheets (応募データ保存) — 任意
# ========================================
# 両方未設定の場合、シート保存はスキップされメール送信のみ動作する。
#
# 設定手順:
#   1. GCPで新規プロジェクト作成 → Sheets API を有効化
#   2. Service Account を作成 → JSONキーをダウンロード
#   3. JSON全体を1行にして（改行を \n にエスケープ）貼り付け
#   4. 保存先スプレッドシートを作成し、Service Accountのemailを「編集者」として共有

# Service Account — 以下どちらか1つを設定。**Base64推奨**。
#
# [推奨] JSONをBase64化した値（改行・エスケープ事故ゼロ）
#   macOS: base64 -i ~/Downloads/simple-records-xxx.json | pbcopy
#   Linux: base64 -w 0 ~/Downloads/simple-records-xxx.json
GOOGLE_SERVICE_ACCOUNT_B64=

# [非推奨] JSONを1行化して設定（改行・クォート事故が起きやすい）
# GOOGLE_SERVICE_ACCOUNT_JSON=

# スプレッドシートのID（URLの /d/ と /edit の間の長い文字列）
GOOGLE_SHEET_ID=

# シート（タブ）名。未指定なら先頭のシートを自動検出（日本語環境: "シート1"、英語環境: "Sheet1"）
# GOOGLE_SHEET_TAB=

# ========================================
# Sentry (エラーモニタリング) — 任意
# ========================================
# 未設定の場合、Sentry初期化はスキップされる。
# サーバ側DSN（Node/Edgeランタイム用）。
SENTRY_DSN=
# クライアント側DSN（ブラウザ用）。通常は SENTRY_DSN と同じ値でOK。
NEXT_PUBLIC_SENTRY_DSN=
